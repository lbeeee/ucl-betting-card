# ===== API KEYS =====
# The Odds API — https://the-odds-api.com (free tier: 500 req/mo, paid ~$20/mo)
THE_ODDS_API_KEY=your_key_here

# API-Football via RapidAPI — https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=your_key_here

# Anthropic API — for AI-powered injury analysis
ANTHROPIC_API_KEY=your_key_here

# ===== CONFIG =====
# How often to poll for live odds (ms). 60000 = 1 minute
NEXT_PUBLIC_ODDS_POLL_INTERVAL=60000

# How often to poll for live scores during matches (ms). 30000 = 30 seconds
NEXT_PUBLIC_SCORES_POLL_INTERVAL=30000
